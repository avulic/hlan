@model HLAN.Models.Entitie.Utakmica


@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<h1>Create</h1>

<h4>Utakmica</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <span class="text-danger">@ViewData["Error"]</span>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Datum" class="control-label"></label>
                <input asp-for="Datum" class="form-control" />
                <span asp-validation-for="Datum" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Sezona.Id" class="control-label">Sezona:</label>
                @Html.DropDownListFor(x => Model.Sezona.Id, ViewBag.Sezone as IEnumerable<SelectListItem>, "-- Select --", null)
            </div>
            <div class="form-group">
                <label asp-for="Kolo.Id" class="control-label">Kolo:</label>
                @Html.DropDownListFor(x => Model.Kolo.Id, ViewBag.Kola as IEnumerable<SelectListItem>, "-- Select --", null)
            </div>
            <div class="form-group">
                @Html.DropDownListFor(x => Model.Domaci.Id, ViewBag.Klubovi as IEnumerable<SelectListItem>, "-- Select --", null)
                <span asp-validation-for="Domaci.Id" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RezDomaci" class="control-label"></label>
                <input asp-for="RezDomaci" class="form-control" />
                <span asp-validation-for="RezDomaci" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Gosti.Id" class="control-label">Gosti:</label>
                @Html.DropDownListFor(x => Model.Gosti.Id, ViewBag.Klubovi as IEnumerable<SelectListItem>, "-- Select --", null)
                <span asp-validation-for="Gosti.Id" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RezGosti" class="control-label"></label>
                <input asp-for="RezGosti" class="form-control" />
                <span asp-validation-for="RezGosti" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

